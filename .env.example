CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=0
COLLAB_TOKEN_TTL_SECONDS=600
WS_MAX_MESSAGE_BYTES=1048576
WS_MAX_MESSAGES_PER_SECOND=50
WS_MAX_CONNECTIONS_PER_USER_DOC=5
